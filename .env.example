# Note: No ANTHROPIC_API_KEY needed — uses your local Claude Code credentials.

# Arcade — get these from https://api.arcade.dev/dashboard
ARCADE_API_KEY=arc_...
ARCADE_GATEWAY_SLUG=your-gateway-slug
ARCADE_USER_ID=you@example.com

# Linear — find these in Linear > Settings > API
LINEAR_TEAM_ID=
LINEAR_IN_PROGRESS_STATE_ID=
LINEAR_IN_REVIEW_STATE_ID=
# Optional — used for completed / blocked issues
LINEAR_DONE_STATE_ID=
LINEAR_NEEDS_CLARIFICATION_STATE_ID=

# Models (optional — defaults shown)
ORCHESTRATOR_MODEL=claude-haiku-4-5-20251001
CODING_AGENT_MODEL=claude-sonnet-4-6
GITHUB_AGENT_MODEL=claude-haiku-4-5-20251001
LINEAR_AGENT_MODEL=claude-haiku-4-5-20251001
ANALYZER_AGENT_MODEL=claude-haiku-4-5-20251001

# Max issues to work on in parallel
MAX_CONCURRENT_ISSUES=3
